# ipd-app = the LOCAL student app. Copy this file to .env  (.env is git-ignored).
#
# It runs on your own machine: practice + run tournaments locally and fetch strategies
# from the class website. NO Firebase, NO login, NO secrets. (Login + submission + results
# live on the separate website, ipd-hub.) It runs with an empty .env — you only need the
# two values below to connect to the class site.

# --- Connect to the class website (your instructor gives you these two) ---
# Set them to see classmates' submitted strategies in the Hub and to submit your own.
# Leave HUB_BASE_URL blank to run fully offline (the Hub just shows nothing to fetch).
HUB_BASE_URL=
HUB_API_TOKEN=

# --- Optional (you normally don't need these) ---
# The app already runs in local/development mode with a built-in session key. Uncomment
# only if you want a stable session key across restarts or to change the mode.
# FLASK_SECRET_KEY=
# FLASK_ENV=development
