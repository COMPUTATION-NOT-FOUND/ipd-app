# ipd-app = the LOCAL student app. Copy this file to .env. .env is git-ignored.
#
# This app runs on the student's own machine: practice + run tournaments locally and
# fetch strategies from the website. It has NO Firebase, NO login, and NO secrets.
# (Login + submission + results live on the separate website, ipd-hub.)

# Flask session signing key (any random value is fine locally). Generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Local development on localhost (HTTP).
FLASK_ENV=development
FLASK_DEBUG=False
# Single local owner — no login needed to practice.
LOCAL_MODE=true

# --- The website to fetch submitted strategies from ---
# Point HUB_BASE_URL at the deployed website; HUB_API_TOKEN must match the class token
# configured on that website. Leave HUB_BASE_URL blank to disable the Hub page.
HUB_BASE_URL=
HUB_API_TOKEN=

# --- Practice limits (relaxed — compute runs on your own CPU) ---
MAX_PRACTICE_STRATEGIES=50
MAX_PRACTICE_ROUNDS=1000
MAX_NPLAYER_STRATEGIES=50
MAX_NPLAYER_ROUNDS=5000
MAX_ADMIN_STRATEGIES=200
MAX_NPLAYER_CORES=64
MAX_STRATEGY_CODE_BYTES=20000
# No per-match wall-clock cap on your own machine (0 disables it).
MATCH_TIME_BUDGET_SECONDS=0
WEIGHT_GRID_STEP=0.1
MAX_SWEEP_COMPOSITIONS=24
